-- AUTO FARM (ROAD TRIP) - NO DELAY
task.spawn(function()
    local rtStart, rtEnd = Vector3.new(-5300, -15, -1175), Vector3.new(-4109, -15, 4423)
    while true do
        task.wait(0.1)
        if rtRunning then
            pcall(function()
                local hum = LP.Character:FindFirstChildOfClass("Humanoid"); local seat = hum.SeatPart
                if seat then
                    local car = seat.Parent; while car and not car:IsA("Model") do car = car.Parent end
                    local function drive(target)
                        while rtRunning and (seat.Position - target).Magnitude > 25 do
                            seat.AssemblyLinearVelocity = (target - seat.Position).Unit * rtSpeed
                            car:PivotTo(CFrame.new(seat.Position, target))
                            RunService.Heartbeat:Wait()
                        end
                    end
                    rtInfo.Text = "STATUS: FORWARD"; drive(rtEnd)
                    rtInfo.Text = "STATUS: BACKWARD"; drive(rtStart)
                end
            end)
        end
    end
end)

