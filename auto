-- FUNGSI SUPER LOW GRAPHIC + PURGE
local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        
        for _, v in pairs(Workspace:GetDescendants()) do
            local name = v.Name:lower()
            if name:find("traffic") or name:find("npc") or name:find("bot") or name:find("car_") then
                if not v:IsDescendantOf(LP.Character) then v:Destroy() end
            elseif v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                if name:find("tree") or name:find("grass") or name:find("bush") or name:find("leaf") then
                    v:Destroy()
                end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sky") or v:IsA("Explosion") then
                v:Destroy()
            elseif v:IsA("MeshPart") then
                v.MeshId = ""
            end
        end
    end)
end

-- FUNGSI CLOSE PRIZE POPUP
local function closePrizePopup()
    pcall(function()
        for _, gui in pairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "DeltaAutoFarm" then
                for _, btn in pairs(gui:GetDescendants()) do
                    if btn:IsA("ImageButton") or btn:IsA("TextButton") then
                        local n = btn.Name:lower()
                        local t = (btn:IsA("TextButton") and btn.Text:lower()) or ""
                        if n == "x" or n:find("close") or t == "x" or t:find("close") or n:find("exit") then
                            if btn.Visible and btn.AbsoluteSize.X > 0 then
                                local pos = btn.AbsolutePosition
                                local size = btn.AbsoluteSize
                                VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 45))
                                pcall(function()
                                    for _, conn in pairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end
                                    for _, conn in pairs(getconnections(btn.MouseButton1Down)) do conn:Fire() end
                                    for _, conn in pairs(getconnections(btn.Activated)) do conn:Fire() end
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local m = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if m then return m.Value end   
    end   
    return 0   
end   

