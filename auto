-- FUNGSI SUPER LOW GRAPHIC + PURGE
local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        
        for _, v in pairs(Workspace:GetDescendants()) do
            local name = v.Name:lower()
            if name:find("traffic") or name:find("npc") or name:find("bot") or name:find("car_") then
                if not v:IsDescendantOf(LP.Character) then v:Destroy() end
            elseif v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                if name:find("tree") or name:find("grass") or name:find("bush") or name:find("leaf") then
                    v:Destroy()
                end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sky") or v:IsA("Explosion") then
                v:Destroy()
            elseif v:IsA("MeshPart") then
                v.MeshId = ""
            end
        end
    end)
end

