-- FUNGSI AMBIL UANG
local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local moneyObj = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if moneyObj then return moneyObj.Value end   
    end   
    return 0   
end   

-- FUNGSI CLAIM AGGRESIF
local function claimEverything()
    status.Text = "SCANNING REMOTES..."
    local foundCount = 0
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            if name:find("claim") or name:find("reward") or name:find("daily") or name:find("quest") or name:find("gift") or name:find("collect") then
                foundCount = foundCount + 1
                task.spawn(function()
                    for i = 1, 20 do 
                        pcall(function()
                            if v:IsA("RemoteEvent") then v:FireServer(i) v:FireServer(tostring(i)) else v:InvokeServer(i) end
                        end)
                    end
                end)
            end
        end
    end
    status.Text = foundCount == 0 and "NO REMOTE FOUND!" or "CLAIMED ("..foundCount.." REMOTES)"
    task.wait(2)
    status.Text = running and "RUNNING..." or "READY (V56.8)"
end

