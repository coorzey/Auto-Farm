local HttpService = game:GetService("HttpService")
local httpRequest = (syn and syn.request) or (http and http.request) or http_request or request

local function sendWebhook(url, gain, total, races, statusType)
    if not url or url == "" then return end
    local title = "🚀 CORRZEY HUB - AUTO REPORT"
    local color = 65430
    if statusType == "OFFLINE" then title = "⚠️ ACCOUNT DISCONNECTED"; color = 16711680
    elseif statusType == "STUCK" then title = "⏳ ALERT: FARM STUCK (4 MIN NO PROFIT)"; color = 16753920 end
    
    local fpsStr = fpsLab.Text:gsub("FPS: ", "")
    local memStr = tostring(math.floor(Stats:GetTotalMemoryUsageMb())) .. " MB"
    
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["color"] = color,
            ["fields"] = {
                {["name"] = "👤 Player", ["value"] = "||" .. tostring(LP.Name) .. "||", ["inline"] = true},
                {["name"] = (statusType == "OFFLINE" or statusType == "STUCK") and "💰 Total Profit" or "💰 Race Profit", ["value"] = "```$" .. tostring((statusType == "OFFLINE" or statusType == "STUCK") and total or gain) .. "```", ["inline"] = true},
                {["name"] = "🏁 Total Races", ["value"] = tostring(races) .. " Races", ["inline"] = true},
                {["name"] = "⚡ Performance", ["value"] = "FPS: " .. fpsStr .. " | RAM: " .. memStr, ["inline"] = false},
            },
            ["footer"] = {["text"] = "V58.6 Cloud Optimized • " .. os.date("%X")},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    local payload = HttpService:JSONEncode(data)
    local function executeRequest()
        pcall(function()
            if httpRequest then httpRequest({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
            else HttpService:PostAsync(url, payload) end
        end)
    end
    if statusType == "OFFLINE" then executeRequest() else task.spawn(executeRequest) end
end

