-- [ULTRASONIC FIX] FUNGSI AUTO USE 2X CASH
local function autoUse2xCash()
    if not use2xCashEnabled then return end
    pcall(function()
        -- Deteksi status Inactive secara mendalam
        local isInactive = false
        for _, v in pairs(PlayerGui:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Text == "Inactive" or v.Text:find("00:00")) then
                if v.Visible then isInactive = true break end
            end
        end

        if isInactive then
            -- 1. Cari Tombol Store (Berdasarkan Screenshot: Tombol Kuning/Store)
            for _, b in pairs(PlayerGui:GetDescendants()) do
                if (b:IsA("ImageButton") or b:IsA("TextButton")) and (b.Name == "Store" or b.Name == "Shop") then
                    local pos = b.AbsolutePosition
                    local size = b.AbsoluteSize
                    VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 50))
                    
                    -- Paksa buka via event
                    pcall(function() b.Activated:Connect() end)
                    task.wait(1.2)
                    break
                end
            end

            -- 2. Cari Tombol USE (Warna Biru & Teks Use)
            local foundUse = false
            for _, u in pairs(PlayerGui:GetDescendants()) do
                if u:IsA("TextButton") and u.Text:find("Use") and u.Visible then
                    -- Verifikasi warna biru (opsional tapi membantu)
                    local pos = u.AbsolutePosition
                    local size = u.AbsoluteSize
                    
                    -- Klik Berulang 3x untuk memastikan teregistrasi
                    for i = 1, 3 do
                        VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 50))
                        pcall(function()
                            for _, conn in pairs(getconnections(u.MouseButton1Click)) do conn:Fire() end
                        end)
                        task.wait(0.2)
                    end
                    foundUse = true
                    task.wait(0.5)
                    break
                end
            end

            -- 3. Tutup Menu Store
            if foundUse then
                for _, x in pairs(PlayerGui:GetDescendants()) do
                    if (x.Name == "Close" or x.Name == "Exit" or x.Text == "X") and x.Visible then
                        local xPos = x.AbsolutePosition
                        local xSize = x.AbsoluteSize
                        VirtualUser:ClickButton1(Vector2.new(xPos.X + (xSize.X/2), xPos.Y + (xSize.Y/2) + 50))
                        break
                    end
                end
            end
        end
    end)
end

