                    for _, p in pairs(Players:GetPlayers()) do 
                        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local rivalHum = p.Character:FindFirstChildOfClass("Humanoid")
                            if (p.Character.HumanoidRootPart.Position - startPos).Magnitude < 20 and (rivalHum and rivalHum.SeatPart and rivalHum.SeatPart:IsA("VehicleSeat")) then 
                                rivalFound = true 
                            end 
                        end
                    end
                until not running or rivalFound
                
                if running and rivalFound then
                    moneyBeforeRace = getPlayerMoney()
                    for i = 18, 1, -1 do 
                        if not running then break end; 
                        hubHeader.Text = "• STARTING: "..i.."s"; 
                        if seat then 
                            seat.AssemblyLinearVelocity = Vector3.new(0,0,0) 
                            seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
                        end
                        task.wait(1) 
                    end
                    
                    if running then
                        for i, d in ipairs(path) do
