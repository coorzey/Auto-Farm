-- MAIN LOOP
task.spawn(function()   
    while true do   
        task.wait(0.5)   
        if running then   
            local leaderstats = LP:FindFirstChild("leaderstats")
            local moneyObj = leaderstats and (leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash"))
            local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")   
            local seat = hum and hum.SeatPart   

            if seat and seat:IsA("VehicleSeat") then   
                local car = seat.Parent   
                while car and not car:IsA("Model") do car = car.Parent end   
                car:PivotTo(CFrame.new(startPos + Vector3.new(0,5,0)) * CFrame.Angles(0, math.rad(startRot), 0))   
                seat.AssemblyLinearVelocity = Vector3.zero
                
                status.Text = "WAITING RIVAL..."; status.TextColor3 = Color3.fromRGB(0, 255, 150)
                
                local rivalFound = false
                repeat
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            if (p.Character.HumanoidRootPart.Position - startPos).Magnitude < 50 then rivalFound = true break end
                        end
                    end
                    task.wait(0.5)
                until rivalFound or not running

                if running and rivalFound then   
                    moneyBeforeRace = moneyObj and moneyObj.Value or 0   
                    for i = 25, 0, -1 do
                        if not running then break end
                        status.Text = "RIVAL FOUND! START IN: "..i.."s"
                        status.TextColor3 = Color3.fromRGB(255, 165, 0); task.wait(1)
                    end
                    
                    if running then   
                        -- MULAI TELEPORT DENGAN CONTINUOUS LOW GRAPHIC
                        for i, d in ipairs(path) do   
                            if not running or not seat.Parent then break end   
                            
                            status.Text = "DYNAMIC TELEPORT ("..i.."/41)"
                            status.TextColor3 = COLOR_YELLOW
                            
                            -- FORCE LOW GRAPHIC DI SETIAP TITIK (Mencegah lag saat pindah area)
                            applyDeepClean() 
                            
                            local cf = CFrame.new(d.pos[1], d.pos[2]+5, d.pos[3]) * CFrame.Angles(0, math.rad(d.rot), 0)   
                            car:PivotTo(cf)   
                            seat.AssemblyLinearVelocity = cf.LookVector * 150   
                            task.wait(math.random(20, 25) / 10)   
                        end   
                        
                        status.Text = "SYNCING..."; task.wait(3)   
                        local gain = (moneyObj and moneyObj.Value or 0) - moneyBeforeRace   
                        if gain > 0 then   
                            totalMoneyEarned = totalMoneyEarned + gain; sessionRaces = sessionRaces + 1   
                            moneyLabel.Text = "Profit: $" .. totalMoneyEarned; raceLabel.Text = "Races: " .. sessionRaces   
                        end   
                        status.Text = "RESTARTING..."; task.wait(2)   
                    end   
                end   
            else status.Text = "SIT IN CAR!" end   
        end   
    end   
end)

