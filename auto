-- FUNGSI SUPER LOW GRAPHIC + PURGE (DIPANGGIL BERULANG)
local function applyDeepClean()
    -- Optimasi Global
    settings().Rendering.QualityLevel = 1
     Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    
    for _, v in pairs(Workspace:GetDescendants()) do
        local name = v.Name:lower()
        -- Hapus NPC/Traffic
        if name:find("traffic") or name:find("npc") or name:find("bot") then
            if not v:IsDescendantOf(LP.Character) then v:Destroy() end
        -- Hapus Objek Berat & Ganti Material
        elseif v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if name:find("tree") or name:find("grass") or name:find("bush") or name:find("leaf") then
                v:Destroy()
            end
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sky") then
            v:Destroy()
        end
    end
end

