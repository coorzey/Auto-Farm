                            profitLab.Text = "Profit: $" .. totalMoneyEarned; racesLab.Text = "Races: " .. sessionRaces
                        end
                        hubHeader.Text = "• LOOP RESTARTING..."
                        task.wait(2)
                    end
                end
            else hubHeader.Text = "• SIT IN CAR!" end
        end
    end
end)

