-- MAIN THREAD (DIPERBARUI DENGAN STATUS TELEPORT)
task.spawn(function()   
    while true do   
        task.wait(0.5)   
        if running then   
            local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")   
            local seat = hum and hum.SeatPart   
            if seat and seat:IsA("VehicleSeat") then   
                local car = seat.Parent   
                while car and not car:IsA("Model") do car = car.Parent end   
                car:PivotTo(CFrame.new(startPos + Vector3.new(0,5,0)) * CFrame.Angles(0, math.rad(startRot), 0))   
                seat.AssemblyLinearVelocity = Vector3.new(0,0,0)   
                
                status.Text = "WAITING FOR RIVAL..."   
                while running and (function()
                    local count = 0
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local d = (p.Character.HumanoidRootPart.Position - startPos).Magnitude
                            if d < 50 then count = count + 1 end
                        end
                    end
                    return count
                end)() == 0 do task.wait(1) end   
                   
                if running then   
                    moneyBeforeRace = getPlayerMoney()   
                    for i = 25, 1, -1 do   
                        if not running then break end   
                        status.Text = "STARTING IN: "..i.."s"   
                        task.wait(1)   
                    end   
                    
                    if running then   
                        -- PERUBAHAN STATUS DISINI
                        status.TextColor3 = COLOR_YELLOW
                        status.Text = "TELEPORTING..." 
                        
                        for i, d in ipairs(path) do   
                            if not running or not seat.Parent then break end   
                            
                            -- STATUS DYNAMIC TELEPORT
                            status.Text = "DYNAMIC TP: ["..i.."/"..#path.."]"
                            
                            local cf = CFrame.new(d.pos[1], d.pos[2]+5, d.pos[3]) * CFrame.Angles(0, math.rad(d.rot), 0)   
                            car:PivotTo(cf)   
                            seat.AssemblyLinearVelocity = cf.LookVector * 150   
                            task.wait(math.random(20, 25) / 10)   
                        end   
                        
                        status.TextColor3 = Color3.fromRGB(0, 255, 150)
                        status.Text = "FINISH! SYNCING..."   
                        task.wait(3)   
                        local moneyAfter = getPlayerMoney()   
                        local gain = moneyAfter - moneyBeforeRace   
                        if gain > 0 then   
                            totalMoneyEarned = totalMoneyEarned + gain   
                            sessionRaces = sessionRaces + 1   
                            moneyLabel.Text = "Profit: $" .. totalMoneyEarned   
                            raceLabel.Text = "Races: " .. sessionRaces   
                        end   
                        status.Text = "RESTARTING..."   
                        task.wait(2)   
                    end   
                end   
            else   
                status.Text = "PLEASE SIT IN CAR!"   
            end   
        end   
    end   
end)
